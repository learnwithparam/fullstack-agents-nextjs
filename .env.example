# Default provider for /api/chat (multi-step agent with tool calling)
# OpenRouter works with one key for many models
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-12b-it

# Optional: Mistral (uncomment and set LLM_PROVIDER=mistral to use)
# MISTRAL_API_KEY=your_mistral_api_key_here
# MISTRAL_MODEL=mistral-large-latest

# Optional: Google Gemini (uncomment and set LLM_PROVIDER=google to use)
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-2.5-flash-lite
